# Supabase / PostgreSQL
SL_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SL_SUPABASE_URL=https://[project-ref].supabase.co
SL_SUPABASE_KEY=[anon-key]

# APIs
SL_COMPANIES_HOUSE_API_KEY=
SL_GITHUB_TOKEN=
SL_ANTHROPIC_API_KEY=
SL_RESEND_API_KEY=

# SEC EDGAR requires a User-Agent with contact info
SL_SEC_USER_AGENT=StartupLens your-email@example.com

# CRM / alerts
SL_AIRTABLE_API_KEY=
SL_AIRTABLE_BASE_ID=
SL_AIRTABLE_TABLE_NAME=Deals
SL_ALERT_EMAIL_TO=
SL_ALERT_EMAIL_FROM=StartupLens <alerts@startuplens.local>
SL_QUIET_HOURS_START=22
SL_QUIET_HOURS_END=7

# Governance
SL_DATA_RETENTION_DAYS=365
SL_PII_REDACTION_ENABLED=true
SL_LEGAL_DISCLAIMER_TEXT=For personal research only. Not investment advice or financial promotion.
